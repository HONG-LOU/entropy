# Copy this file to seed.env and replace every example value.
ENTCOIN_SEED_DOMAIN=seed1.example.com
ENTCOIN_ACME_EMAIL=ops@example.com
ENTCOIN_INSTALL_DIR=C:\EntcoinSeed
ENTCOIN_DATA_DIR=D:\EntcoinSeedData\node
ENTCOIN_CADDY_DATA_DIR=D:\EntcoinSeedData\caddy
ENTCOIN_LOG_DIR=D:\EntcoinSeedLogs
ENTCOIN_LISTEN_ADDRESS=127.0.0.1:47821
ENTCOIN_BOOTSTRAP_PEER=
ENTCOIN_BOOTSTRAP_MANIFEST_URLS=https://raw.githubusercontent.com/HONG-LOU/entcoin/main/network/mainnet.json,https://cdn.jsdelivr.net/gh/HONG-LOU/entcoin@main/network/mainnet.json
ENTCOIN_PRUNE_DEPTH=0
ENTCOIN_DISABLE_DISCOVERY=true
ENTCOIN_TRUST_LOOPBACK_PROXY=true
