# Copy this file to seed.env and replace every example value.
ENTROPY_SEED_DOMAIN=seed1.example.com
ENTROPY_ACME_EMAIL=ops@example.com
ENTROPY_INSTALL_DIR=C:\EntropySeed
ENTROPY_DATA_DIR=D:\EntropySeedData\node
ENTROPY_CADDY_DATA_DIR=D:\EntropySeedData\caddy
ENTROPY_LOG_DIR=D:\EntropySeedLogs
ENTROPY_LISTEN_ADDRESS=127.0.0.1:47821
ENTROPY_BOOTSTRAP_PEER=
ENTROPY_BOOTSTRAP_MANIFEST_URLS=https://raw.githubusercontent.com/HONG-LOU/entropy/main/network/mainnet.json,https://cdn.jsdelivr.net/gh/HONG-LOU/entropy@main/network/mainnet.json
ENTROPY_PRUNE_DEPTH=0
ENTROPY_DISABLE_DISCOVERY=true
ENTROPY_TRUST_LOOPBACK_PROXY=true
